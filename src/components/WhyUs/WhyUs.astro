---
import { Image } from "astro:assets";
import comunidadBg from "../../assets/whyus-comunidad.jpg";
import entrenadoresBg from "../../assets/whyus-entrenadores.jpg";
import ambienteBg from "../../assets/whyus-ambiente.jpg";
---

<section class="why-us" id="nosotros" data-animate>
  <div class="why-us__bg-text" aria-hidden="true">NOSOTROS</div>

  <div class="why-us__layout">
    <header class="why-us__intro">
      <p class="why-us__tag" data-animate>// NOSOTROS</p>
      <h2 class="why-us__title" data-animate>
        <span class="why-us__title-line">POR QUÉ </span>
        <span class="why-us__title-line why-us__title-line--accent">ELEGIRNOS</span>
      </h2>
      <p class="why-us__desc" data-animate>
        En Gym Sáenz Peña no somos solo máquinas y pesas. Somos la comunidad que te espera cada día, los entrenadores que saben tu nombre y el ambiente que te hace querer volver.
      </p>
    </header>

    <div class="why-us__cards">
      <article class="why-us__card" data-animate>
        <Image src={comunidadBg} alt="Grupo de personas entrenando juntas" class="why-us__card-bg" width={800} height={500} />
        <span class="why-us__card-overlay" aria-hidden="true"></span>
        <div class="why-us__card-body">
          <span class="why-us__card-number" aria-hidden="true">01</span>
          <h3 class="why-us__card-title">COMUNIDAD REAL</h3>
          <p class="why-us__card-desc">
            Acá no sos un número. Todos se conocen, se apoyan y crecen juntos. Somos un grupo que entrena, no solo un lugar con máquinas.
          </p>
        </div>
      </article>

      <article class="why-us__card" data-animate>
        <Image src={entrenadoresBg} alt="Entrenador ayudando a un alumno" class="why-us__card-bg" width={800} height={500} />
        <span class="why-us__card-overlay" aria-hidden="true"></span>
        <div class="why-us__card-body">
          <span class="why-us__card-number" aria-hidden="true">02</span>
          <h3 class="why-us__card-title">ENTRENADORES PRESENTES</h3>
          <p class="why-us__card-desc">
            Cada clase tiene un profe que está ahí con vos. Corrigiendo, motivando, empujando. Nada de máquinas solas y mirar el celular.
          </p>
        </div>
      </article>

      <article class="why-us__card" data-animate>
        <Image src={ambienteBg} alt="Personas entrenando en un ambiente energético" class="why-us__card-bg" width={800} height={500} />
        <span class="why-us__card-overlay" aria-hidden="true"></span>
        <div class="why-us__card-body">
          <span class="why-us__card-number" aria-hidden="true">03</span>
          <h3 class="why-us__card-title">AMBIENTE QUE MUEVE</h3>
          <p class="why-us__card-desc">
            La energía del grupo, la música, el compromiso. Un lugar donde las excusas se quedan afuera y las ganas de volver crecen cada día.
          </p>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .why-us {
    position: relative;
    padding: var(--space-xl) var(--container-padding);
    background: var(--color-bg);
    overflow: hidden;
    border-top: 1px solid var(--color-border);
  }

  .why-us__bg-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-display);
    font-size: clamp(5rem, 20vw, 16rem);
    font-weight: var(--fw-extrablack);
    color: transparent;
    -webkit-text-stroke: 1px var(--color-border);
    opacity: 0.15;
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    line-height: 1;
    z-index: 0;
  }

  .why-us__layout {
    position: relative;
    z-index: 1;
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  .why-us__tag {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-widest);
    color: var(--color-accent);
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }

  .why-us__title {
    font-family: var(--font-display);
    font-weight: var(--fw-extrablack);
    text-transform: uppercase;
    line-height: 0.92;
    margin-bottom: var(--space-lg);
  }

  .why-us__title-line {
    display: block;
    font-size: clamp(2.2rem, 8vw, 4.5rem);
    color: var(--color-text);
  }

  .why-us__title-line--accent {
    color: var(--color-accent);
  }

  .why-us__desc {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 480px;
  }

  .why-us__cards {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .why-us__card {
    position: relative;
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-lg);
    background-color: #111;
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: border-color var(--transition-fast), transform var(--transition-fast);
  }

  .why-us__card:hover {
    border-color: var(--color-accent);
    transform: scale(1.02);
  }

  .why-us__card-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    z-index: 0;
  }

  .why-us__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.4) 60%, transparent 100%);
    pointer-events: none;
    z-index: 1;
  }

  .why-us__card-number {
    position: relative;
    z-index: 2;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--fw-bold);
    color: var(--color-accent);
    letter-spacing: var(--tracking-wide);
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .why-us__card-body {
    position: relative;
    z-index: 2;
    flex: 1;
  }

  .why-us__card-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--fw-bold);
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-sm);
  }

  .why-us__card-desc {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  .why-us__tag {
    transition-delay: 0s;
  }

  .why-us__title {
    transition-delay: 0.1s;
  }

  .why-us__desc {
    transition-delay: 0.2s;
  }

  .why-us__card:nth-child(1) {
    transition-delay: 0.25s;
  }

  .why-us__card:nth-child(2) {
    transition-delay: 0.35s;
  }

  .why-us__card:nth-child(3) {
    transition-delay: 0.45s;
  }

  @media (min-width: 768px) {
    .why-us__card {
      padding: var(--space-xl);
    }
  }

  @media (min-width: 1024px) {
    .why-us {
      padding: var(--space-2xl) var(--container-padding);
    }

    .why-us__layout {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
      align-items: start;
    }

    .why-us__intro {
      position: sticky;
      top: var(--space-2xl);
    }

    .why-us__cards {
      gap: var(--space-lg);
    }
  }
</style>
