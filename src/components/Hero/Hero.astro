---
import { Image } from "astro:assets";
import heroBg from "../../assets/hero-bg.jpg";
---

<section class="hero">
  <div class="hero__visual" aria-hidden="true">
    <Image src={heroBg} alt="Personas entrenando en el gimnasio" class="hero__visual-bg" width={1200} height={800} />
    <div class="hero__visual-overlay"></div>
  </div>

  <div class="hero__content">
    <p class="hero__subtitle" data-animate>SÁENZ PEÑA, BUENOS AIRES</p>

    <h1 class="hero__title" data-animate>
      <span class="hero__title-line hero__title-line--full">ENTRENÁ</span>
      <span class="hero__title-line">
        <span class="hero__title-muted">EN </span>
        <span class="hero__title-white">TU BARRIO</span>
      </span>
    </h1>

    <div class="hero__ctas" data-animate>
      <a href="https://wa.me/541123456789" target="_blank" rel="noopener noreferrer" class="hero__cta hero__cta--primary">
        Reservá tu clase de prueba gratis
        <span class="hero__cta-arrow" aria-hidden="true">→</span>
      </a>
      <a href="#nosotros" class="hero__cta hero__cta--secondary">Conocé el gimnasio</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .hero__visual {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__visual-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center 20%;
  }

  .hero__visual-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 0%, transparent 50%, var(--color-bg) 100%);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: var(--container-padding);
    padding-top: 6rem;
    padding-bottom: 3rem;
  }

  .hero__subtitle {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
  }

  .hero__title {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    line-height: 0.88;
    margin-bottom: var(--space-xl);
  }

  .hero__title-line {
    display: block;
  }

  .hero__title-line--full {
    font-size: clamp(2.8rem, 14vw, 8rem);
    color: var(--color-text);
  }

  .hero__title-white {
    font-size: clamp(2.8rem, 14vw, 8rem);
    color: var(--color-text);
  }

  .hero__title-muted {
    font-size: clamp(2.8rem, 14vw, 8rem);
    color: var(--color-text);
    -webkit-text-fill-color: transparent;
    -webkit-text-stroke: 1.5px var(--color-text-muted);
    opacity: 0.4;
  }

  .hero__ctas {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.2s ease;
    border: none;
  }

  .hero__cta--primary {
    background: var(--color-accent);
    color: var(--color-text);
    padding: 1rem 2rem;
  }

  .hero__cta--primary:hover {
    background: var(--color-accent-hover);
  }

  .hero__cta-arrow {
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .hero__cta--primary:hover .hero__cta-arrow {
    transform: translateX(4px);
  }

  .hero__cta--secondary {
    background: transparent;
    color: var(--color-text-muted);
    padding: 0.75rem 0;
    border-bottom: 1px solid transparent;
  }

  .hero__cta--secondary:hover {
    color: var(--color-text);
    border-bottom-color: var(--color-text-muted);
  }

  .hero__subtitle {
    transition-delay: 0.1s;
  }

  .hero__title {
    transition-delay: 0.2s;
  }

  .hero__ctas {
    transition-delay: 0.35s;
  }

  @media (min-width: 768px) {
    .hero__content {
      padding-top: 8rem;
      padding-bottom: 4rem;
    }

    .hero__title-muted {
      -webkit-text-stroke: 2px var(--color-text-muted);
    }

    .hero__ctas {
      flex-direction: row;
      align-items: center;
      gap: var(--space-lg);
    }

    .hero__visual-bg {
      object-position: center 30%;
    }
  }

  @media (min-width: 1024px) {
    .hero {
      min-height: 100vh;
    }

    .hero__visual {
      width: 55%;
      left: 45%;
    }

    .hero__visual-bg {
      object-position: center 25%;
    }

    .hero__visual-overlay {
      background: linear-gradient(90deg, var(--color-bg) 0%, var(--color-bg) 10%, transparent 35%);
    }

    .hero__content {
      width: 50%;
      padding: var(--space-xl);
      padding-top: var(--space-2xl);
      padding-bottom: var(--space-2xl);
    }
  }
</style>
